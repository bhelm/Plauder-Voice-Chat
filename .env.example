# =============================================================================
# Voice-Chat — Konfigurationsvorlage
# =============================================================================
# Kopiere diese Datei nach .env und trage deine Keys ein. Die .env wird vom
# Server selbst geladen (kein python-dotenv nötig) — bereits gesetzte echte
# ENV-Variablen gewinnen.
#
# Backend-Auswahl über STT_BACKEND / TTS_BACKEND / LLM_BACKEND. Inaktive
# Backends werden NICHT geladen (insb. GPU-Deps werden nie importiert).
#
# Legacy-Kompatibilität: Wenn die neuen Variablen (STT_OPENAI_API_KEY,
# LLM_API_KEY, LLM_MODEL …) fehlen, greift der Server auf OPENAI_API_KEY /
# FIREWORKS_* zurück. Eine minimale .env mit nur OPENAI_API_KEY +
# FIREWORKS_API_KEY reicht also für den Cloud-Default.
# =============================================================================

# === General ===
HOST=0.0.0.0
PORT=8319
AGENT_NAME=Antonia
LOG_LEVEL=INFO

# === Persona / System-Prompt (optional) ===
# Standard: KEINE Persona — nur ein knapper Voice-Hinweis ("kurz fassen, kein
# Markdown/Emoji, wird vorgelesen"). Nützt v.a. den direkten LLM-Betrieb
# (LLM_BACKEND=openai_compat). Bringt das Backend selbst eine Persona mit
# (z.B. ein Agent-Gateway), einfach leer lassen.
SYSTEM_PROMPT=            # z.B.: Du bist Antonia, eine warmherzige Helferin. Sprich knapp.
# SOUL_PATH=/pfad/zu/persona.md   # Alternative: Persona aus Datei (überschreibt SYSTEM_PROMPT)
# VOICE_MODE_SYSTEM=             # Komplett-Override des gesamten System-Prompts
# VOICE_MODE_HINT=              # nur den Voice-Hinweis-Teil ersetzen

# === STT Backend Selection ===
STT_BACKEND=openai            # openai | whisper_local
# --- OpenAI Whisper API ---
STT_OPENAI_API_KEY=           # leer -> Fallback auf OPENAI_API_KEY
STT_OPENAI_MODEL=whisper-1
STT_LANGUAGE=de               # ISO-639-1, leer = Auto-Detect
# --- faster_whisper (lokal, GPU; nur bei STT_BACKEND=whisper_local) ---
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_LOCAL_FILES_ONLY=1
# Halluzinations-Filter ("Thank you"-Geister)
STT_HALLUCINATION_FILTER=1
STT_GHOST_NO_SPEECH_PROB=0.6
STT_GHOST_USE_DURATION=0

# === TTS Backend Selection ===
TTS_BACKEND=openai            # openai | omnivoice_local
# --- OpenAI TTS API ---
TTS_OPENAI_API_KEY=           # leer -> Fallback auf OPENAI_API_KEY
TTS_OPENAI_MODEL=tts-1        # tts-1 | tts-1-hd
TTS_OPENAI_VOICE=nova         # nova | shimmer | alloy | echo | fable | onyx
TTS_OPENAI_FORMAT=pcm
# Sample-Rate des roh-PCM. 24000 = OpenAI-Cloud/Kokoro/XTTS. Nur ändern, wenn der
# Server nachweislich anders liefert (sonst klingt es zu schnell/langsam).
TTS_OPENAI_SAMPLE_RATE=24000
# 1 = speed/UI-Slider lokal per tonhöhen-erhaltender Zeitdehnung umsetzen, statt
# an den Server zu schicken. Für Server, die `speed` ignorieren (z.B. XTTS).
TTS_OPENAI_LOCAL_SPEED=0
TTS_SPEED=1.0                 # 0.5–3.0 (Slider in der UI bis 3×)
# --- OmniVoice (lokal, GPU; nur bei TTS_BACKEND=omnivoice_local) ---
OMNIVOICE_MODEL=k2-fsa/OmniVoice
OMNIVOICE_DEVICE=cuda
OMNIVOICE_MODE=clone          # clone braucht OMNIVOICE_REF_AUDIO
OMNIVOICE_REF_AUDIO=./voices/antonia.wav
OMNIVOICE_REF_TEXT=
OMNIVOICE_LANGUAGE=de

# === LLM Backend Selection ===
LLM_BACKEND=openai_compat     # openai_compat | openclaw
# --- OpenAI-kompatibel (Fireworks, OpenAI, …) ---
LLM_API_KEY=                  # leer -> Fallback auf FIREWORKS_API_KEY
LLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_MODEL=accounts/fireworks/models/glm-5p2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=300
# --- OpenClaw Gateway (legacy; nur bei LLM_BACKEND=openclaw) ---
OPENCLAW_GATEWAY_URL=http://localhost:8080
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=antonia
OPENCLAW_USER_ID=voice-user

# === Turn-Taking ===
DEBOUNCE_MS=1200              # Stille-Fenster bis ein Turn abgeschickt wird
TTS_SENTENCE_SPLIT=0          # 1 = satzweise synthetisieren (niedrigere Erst-Latenz)
TTS_SENTENCE_GAP_MS=120
TTS_MAX_CHARS_PER_CHUNK=220

# === Streaming (Latenz) ===
# STREAMING=1: LLM-Token werden gestreamt, satzweise sofort synthetisiert und als
# PCM-Chunks progressiv an den Browser geschickt (A1+A2). Zusätzlich streamt der
# Browser die Mikro-Frames live mit, während gesprochen wird (B1). Das senkt die
# „Zeit bis zum ersten gesprochenen Wort" deutlich.
# STREAMING=0: klassischer Pfad (erst komplett generieren, dann ein WAV) — als
# Fallback, falls der LLM-Endpoint kein Server-Sent-Events-Streaming kann.
STREAMING=1
TTS_CHUNK_MS=400             # Ziel-Länge je PCM-Chunk in der Audio-Übertragung

# === Wake-Word (Eingabe-Modus, Start-Default AUS) ===
# Wake-Word ist ein Eingabe-Modus (neben VAD & Push-to-Talk), wählbar in der UI.
# Im Wake-Modus lösen nur Segmente, deren Transkript mit dem Wake-Word beginnt
# (Füllwörter wie "Hey"/"Ok" davor erlaubt), einen Turn aus — alles andere wird
# verworfen. Nach einer Antwort bleibt das Gate WAKE_WORD_WINDOW_S offen
# (Folgefragen ohne erneutes Wake-Word).
# WAKE_WORD_ENABLED ist nur der START-Default: 1 = UI startet im Wake-Modus.
WAKE_WORD_ENABLED=0
WAKE_WORD=                   # leer = AGENT_NAME (klein); sonst z.B. antonia
# Verhalten NACH einer Antwort:
#   conversation = Konversationsfenster bleibt WAKE_WORD_WINDOW_S offen,
#                  Folgefragen ohne Weckwort möglich (Standard).
#   alexa        = One-Shot: nach der Antwort schließt das Fenster sofort,
#                  jeder neue Befehl braucht wieder das Weckwort.
WAKE_MODE=conversation       # conversation | alexa
WAKE_WORD_WINDOW_S=8         # Konversationsfenster nach einer Antwort (s)
WAKE_WORD_FUZZY=1            # Whisper-Verhörer tolerieren (Antonja/Anthonia/…)
WAKE_WORD_ANYWHERE=0         # 1 = Wake-Word irgendwo im Satz statt nur am Anfang
WAKE_WORD_STRIP=1            # Wake-Word vor dem LLM aus dem Text schneiden
WAKE_WORD_RATIO=0.78         # Fuzzy-Schwelle (höher = strenger)

# === House Mode (optional, Default aus) ===
HOUSE_MODE=0
HOUSE_DATA_DIR=./house_data

# === Shared API Keys (Fallback, falls STT/TTS/LLM denselben Provider nutzen) ===
OPENAI_API_KEY=sk-...
FIREWORKS_API_KEY=fw_...
