# =============================================================================
# Voice-Chat — configuration template
# =============================================================================
# Copy this file to .env and fill in your keys. The .env is loaded by the
# server itself (no python-dotenv needed) — real ENV variables that are already
# set win.
#
# Backend selection via STT_BACKEND / TTS_BACKEND / LLM_BACKEND. Inactive
# backends are NOT loaded (in particular GPU deps are never imported).
#
# Legacy compatibility: if the new variables (STT_OPENAI_API_KEY, LLM_API_KEY,
# LLM_MODEL …) are missing, the server falls back to OPENAI_API_KEY /
# FIREWORKS_*. So a minimal .env with just OPENAI_API_KEY + FIREWORKS_API_KEY is
# enough for the cloud default.
# =============================================================================

# === General ===
HOST=0.0.0.0
PORT=8319
AGENT_NAME=Antonia
LOG_LEVEL=INFO
# UI/app language: en | de (default en). Drives the browser UI locale (the
# client is i18n EN+DE and renders in this language automatically) AND the
# assistant's default spoken language plus the STT default language. Set to
# `de` to restore the original German experience.
APP_LANGUAGE=en

# === Persona / system prompt (optional) ===
# Default: NO persona — just a terse voice hint ("be concise, no markdown/emoji,
# it is read aloud"). Mostly useful for the direct LLM mode
# (LLM_BACKEND=openai_compat). If the backend itself ships a persona (e.g. an
# agent gateway), just leave this empty.
SYSTEM_PROMPT=            # e.g.: You are Antonia, a warm-hearted helper. Be concise.
# SOUL_PATH=/path/to/persona.md   # Alternative: persona from a file (overrides SYSTEM_PROMPT)
# VOICE_MODE_SYSTEM=             # Full override of the entire system prompt
# VOICE_MODE_HINT=              # Replace only the voice-hint part

# === STT Backend Selection ===
STT_BACKEND=openai            # openai | whisper_local
# --- OpenAI Whisper API ---
STT_OPENAI_API_KEY=           # empty -> falls back to OPENAI_API_KEY
STT_OPENAI_MODEL=whisper-1
STT_LANGUAGE=                 # ISO-639-1; empty = follow APP_LANGUAGE (set explicitly to override)
# --- faster_whisper (local, GPU; only when STT_BACKEND=whisper_local) ---
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_LOCAL_FILES_ONLY=1
# Hallucination filter ("Thank you" ghosts)
STT_HALLUCINATION_FILTER=1
STT_GHOST_NO_SPEECH_PROB=0.6
STT_GHOST_USE_DURATION=0

# === TTS Backend Selection ===
TTS_BACKEND=openai            # openai | omnivoice_local
# --- OpenAI TTS API ---
TTS_OPENAI_API_KEY=           # empty -> falls back to OPENAI_API_KEY
TTS_OPENAI_MODEL=tts-1        # tts-1 | tts-1-hd
TTS_OPENAI_VOICE=nova         # nova | shimmer | alloy | echo | fable | onyx
# Sample rate of the raw PCM. 24000 = OpenAI cloud/Kokoro/XTTS. Only change it if
# the server demonstrably delivers something else (otherwise it sounds too
# fast/slow).
TTS_OPENAI_SAMPLE_RATE=24000
# 1 = apply the speed/UI slider locally via pitch-preserving time-stretch instead
# of sending it to the server. For servers that ignore `speed` (e.g. XTTS).
TTS_OPENAI_LOCAL_SPEED=0
TTS_SPEED=1.0                 # 0.5–3.0 (UI slider goes up to 3×)
# --- OmniVoice (local, GPU; only when TTS_BACKEND=omnivoice_local) ---
OMNIVOICE_MODEL=k2-fsa/OmniVoice
OMNIVOICE_DEVICE=cuda
OMNIVOICE_MODE=clone          # clone needs OMNIVOICE_REF_AUDIO
OMNIVOICE_REF_AUDIO=./voices/antonia.wav
OMNIVOICE_REF_TEXT=
OMNIVOICE_LANGUAGE=           # empty = follow APP_LANGUAGE

# === LLM Backend Selection ===
LLM_BACKEND=openai_compat     # openai_compat | openclaw
# --- OpenAI-compatible (Fireworks, OpenAI, …) ---
LLM_API_KEY=                  # empty -> falls back to FIREWORKS_API_KEY
LLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_MODEL=accounts/fireworks/models/glm-5p2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=300
# --- OpenClaw Gateway (legacy; only when LLM_BACKEND=openclaw) ---
OPENCLAW_GATEWAY_URL=http://localhost:8080
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=antonia
OPENCLAW_USER_ID=voice-user

# === Turn-Taking ===
DEBOUNCE_MS=1200              # silence window before a turn is dispatched
TTS_SENTENCE_SPLIT=0          # 1 = synthesize sentence by sentence (lower first-word latency)
TTS_SENTENCE_GAP_MS=120
TTS_MAX_CHARS_PER_CHUNK=220

# === Streaming (latency) ===
# STREAMING=1: LLM tokens are streamed, synthesized sentence by sentence right
# away and pushed to the browser progressively as PCM chunks (A1+A2). In
# addition, the browser streams the mic frames live while you speak (B1). This
# noticeably lowers the "time to first spoken word".
# STREAMING=0: classic path (generate fully, then one WAV) — as a fallback in
# case the LLM endpoint cannot do Server-Sent-Events streaming.
STREAMING=1
TTS_CHUNK_MS=400             # target length per PCM chunk in the audio transfer

# === Wake word (input mode, start default OFF) ===
# The wake word is an input mode (next to VAD & push-to-talk), selectable in the
# UI. In wake mode only segments whose transcript starts with the wake word
# (filler words like "Hey"/"Ok" in front are allowed) trigger a turn — everything
# else is discarded. After a reply the gate stays open for WAKE_WORD_WINDOW_S
# (follow-up questions without repeating the wake word).
# WAKE_WORD_ENABLED is only the START default: 1 = UI starts in wake mode.
WAKE_WORD_ENABLED=0
WAKE_WORD=                   # empty = AGENT_NAME (lowercased); otherwise e.g. antonia
# Behaviour AFTER a reply:
#   conversation = the conversation window stays open for WAKE_WORD_WINDOW_S,
#                  follow-up questions without the wake word are possible (default).
#   alexa        = one-shot: the window closes immediately after the reply,
#                  every new command needs the wake word again.
WAKE_MODE=conversation       # conversation | alexa
WAKE_WORD_WINDOW_S=8         # conversation window after a reply (s)
WAKE_WORD_FUZZY=1            # tolerate Whisper mishearings (Antonja/Anthonia/…)
WAKE_WORD_ANYWHERE=0         # 1 = wake word anywhere in the sentence instead of only at the start
WAKE_WORD_STRIP=1            # cut the wake word out of the text before the LLM
WAKE_WORD_RATIO=0.78         # fuzzy threshold (higher = stricter)

# === House Mode (optional, default off) ===
HOUSE_MODE=0
HOUSE_DATA_DIR=./house_data

# === Shared API keys (fallback, when STT/TTS/LLM use the same provider) ===
OPENAI_API_KEY=sk-...
FIREWORKS_API_KEY=fw_...
