# =============================================================================
# Voice-Chat — configuration template
# =============================================================================
# Copy this file to .env and fill in your keys. The .env is loaded by the
# server itself (no python-dotenv needed) — real ENV variables that are already
# set win.
#
# Backend selection via STT_BACKEND / TTS_BACKEND / LLM_BACKEND. Inactive
# backends are NOT loaded (in particular GPU deps are never imported).
#
# Legacy compatibility: if the new variables (STT_OPENAI_API_KEY, LLM_API_KEY,
# LLM_MODEL …) are missing, the server falls back to OPENAI_API_KEY /
# FIREWORKS_*. So a minimal .env with just OPENAI_API_KEY + FIREWORKS_API_KEY is
# enough for the cloud default.
# =============================================================================

# === General ===
HOST=0.0.0.0
PORT=8319
AGENT_NAME=Antonia
LOG_LEVEL=INFO
# UI/app language: en | de (default en). Drives the browser UI locale (the
# client is i18n EN+DE and renders in this language automatically) AND the
# assistant's default spoken language plus the STT default language. Set to
# `de` to restore the original German experience.
APP_LANGUAGE=en
# Sub-path to serve the app under, for running behind a reverse proxy. Empty =
# root (default). E.g. BASE_PATH=/voice serves the UI at /voice/ and all routes
# (/voice/ws, /voice/upload, /voice/static/…); the client builds its URLs with
# this prefix. The proxy must forward /voice/ WITHOUT stripping the prefix.
BASE_PATH=

# === Persona / system prompt (optional) ===
# Default: NO persona — just a terse voice hint ("be concise, no markdown/emoji,
# it is read aloud"). Mostly useful for the direct LLM mode
# (LLM_BACKEND=openai_compat). If the backend itself ships a persona (e.g. an
# agent gateway), just leave this empty.
SYSTEM_PROMPT=            # e.g.: You are Antonia, a warm-hearted helper. Be concise.
# SOUL_PATH=/path/to/persona.md   # Alternative: persona from a file (overrides SYSTEM_PROMPT)
# VOICE_MODE_SYSTEM=             # Full override of the entire system prompt
# VOICE_MODE_HINT=              # Replace only the voice-hint part
#   e.g.: Short spoken sentences, no markdown. Nonverbal tags sparingly:
#   [laughter], [sigh]. For real laughter write [laughter] Hahaha!

# === STT Backend Selection ===
STT_BACKEND=openai            # openai | whisper_local
# --- OpenAI Whisper API ---
STT_OPENAI_API_KEY=           # empty -> falls back to OPENAI_API_KEY
STT_OPENAI_MODEL=whisper-1
# Point at a self-hosted, OpenAI-compatible Whisper endpoint (e.g. whisper.cpp /
# faster-whisper-server). Empty -> OpenAI cloud (falls back to OPENAI_BASE_URL).
STT_OPENAI_BASE_URL=
STT_LANGUAGE=                 # ISO-639-1; empty = follow APP_LANGUAGE (set explicitly to override)
# --- faster_whisper (local, GPU; only when STT_BACKEND=whisper_local) ---
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_LOCAL_FILES_ONLY=1
# Hallucination filter ("Thank you"/"Thanks for watching" ghosts on silence)
STT_HALLUCINATION_FILTER=1
STT_GHOST_NO_SPEECH_PROB=0.6  # drop a known ghost phrase when Whisper's no-speech prob is above this
STT_GHOST_USE_DURATION=0      # 1 = also treat short segments (< STT_GHOST_MAX_DUR_S) as ghost candidates
STT_GHOST_MAX_DUR_S=1.5       # segment-length cutoff for the duration heuristic above
# Extra phrases to treat as ghosts, comma-separated (added to the built-in list).
STT_GHOST_EXTRA_PHRASES=

# === TTS Backend Selection ===
TTS_BACKEND=openai            # openai | omnivoice_local
# --- OpenAI TTS API ---
# Also the way to use the standalone OmniVoice server (see omnivoice-openai-wrapper/):
# keep TTS_BACKEND=openai and set TTS_OPENAI_BASE_URL=http://<gpu-box>:8880/v1,
# TTS_OPENAI_MODEL=omnivoice, TTS_OPENAI_VOICE=de_female.
TTS_OPENAI_API_KEY=           # empty -> falls back to OPENAI_API_KEY
TTS_OPENAI_BASE_URL=          # empty -> OpenAI cloud; set for a self-hosted endpoint
TTS_OPENAI_MODEL=tts-1        # tts-1 | tts-1-hd
TTS_OPENAI_VOICE=nova         # nova | shimmer | alloy | echo | fable | onyx
# Sample rate of the raw PCM. 24000 = OpenAI cloud/Kokoro/XTTS. Only change it if
# the server demonstrably delivers something else (otherwise it sounds too
# fast/slow).
TTS_OPENAI_SAMPLE_RATE=24000
# 1 = apply the speed/UI slider locally via pitch-preserving time-stretch instead
# of sending it to the server. For servers that ignore `speed` (e.g. XTTS).
TTS_OPENAI_LOCAL_SPEED=0
TTS_SPEED=1.0                 # default speed; server clamps 0.25–4.0, UI slider 0.7–3.0x
# --- OmniVoice (local, GPU; only when TTS_BACKEND=omnivoice_local) ---
OMNIVOICE_MODEL=k2-fsa/OmniVoice
OMNIVOICE_DEVICE=cuda
OMNIVOICE_MODE=clone          # clone needs OMNIVOICE_REF_AUDIO
OMNIVOICE_REF_AUDIO=./voices/antonia.wav
OMNIVOICE_REF_TEXT=
OMNIVOICE_LANGUAGE=           # empty = follow APP_LANGUAGE

# === LLM Backend Selection ===
LLM_BACKEND=openai_compat     # openai_compat | openclaw
# --- OpenAI-compatible (Fireworks, OpenAI, …) ---
LLM_API_KEY=                  # empty -> falls back to FIREWORKS_API_KEY
LLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_MODEL=accounts/fireworks/models/glm-5p2
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=300
# How many past turns (user+assistant pairs) to keep in the LLM context window.
LLM_HISTORY_TURNS=20
# 1 = on an idle/timeout error, retry the request once (helps cold gateways).
OPENCLAW_RETRY_TIMEOUT=1
# --- OpenClaw Gateway (legacy; only when LLM_BACKEND=openclaw) ---
OPENCLAW_GATEWAY_URL=http://localhost:8080
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=antonia
OPENCLAW_USER_ID=voice-user

# === Turn-Taking ===
DEBOUNCE_MS=1200              # silence window before a turn is dispatched
#DEBOUNCE_MS_MIN=200          # clamp range for the UI pause slider
#DEBOUNCE_MS_MAX=5000
TTS_SENTENCE_SPLIT=0          # 1 = synthesize sentence by sentence (lower first-word latency)
TTS_SENTENCE_GAP_MS=120
TTS_MAX_CHARS_PER_CHUNK=220

# === Streaming (latency) ===
# STREAMING=1: LLM tokens are streamed, synthesized sentence by sentence right
# away and pushed to the browser progressively as PCM chunks (A1+A2). In
# addition, the browser streams the mic frames live while you speak (B1). This
# noticeably lowers the "time to first spoken word".
# STREAMING=0: classic path (generate fully, then one WAV) — as a fallback in
# case the LLM endpoint cannot do Server-Sent-Events streaming.
STREAMING=1
TTS_CHUNK_MS=400             # target length per PCM chunk in the audio transfer
TTS_FIRST_CHUNK_CHARS=100    # force-flush the FIRST sentence to TTS after this many
                             # chars (cut at a clause boundary if possible) — a long
                             # opening sentence otherwise delays first audio; 0 = off
# Opus audio compression for the browser link (kill switch, default on).
# When on AND the opus codec is usable (opuslib + system libopus, see
# requirements.txt), hello advertises audio.opusIn/opusOut and WebCodecs-capable
# browsers switch the mic uplink (~24 kbit/s instead of raw f32 ~512 kbit/s)
# and the TTS downlink (VCT3, ~48 kbit/s instead of raw PCM16 ~384 kbit/s) to
# opus — mainly useful on mobile links. Clients/servers without support keep
# the raw paths automatically; AUDIO_OPUS=0 forces raw PCM everywhere.
#AUDIO_OPUS=1
# B2 interim transcripts: while a segment streams in, periodically transcribe
# the growing buffer (transcript.partial). Default on only for whisper_local —
# with a CLOUD STT backend every partial is a PAID API call.
#STT_PARTIAL=1
#STT_PARTIAL_MIN_INTERVAL_MS=700   # min pause between partial STT runs
#STT_PARTIAL_MIN_NEW_MS=500        # min new audio before another partial run

# === Wake word (input mode, start default OFF) ===
# The wake word is an input mode (next to VAD & push-to-talk), selectable in the
# UI. In wake mode only segments whose transcript starts with the wake word
# (filler words like "Hey"/"Ok" in front are allowed) trigger a turn — everything
# else is discarded. After a reply the gate stays open for WAKE_WORD_WINDOW_S
# (follow-up questions without repeating the wake word).
# WAKE_WORD_ENABLED is only the START default: 1 = UI starts in wake mode.
WAKE_WORD_ENABLED=0
WAKE_WORD=                   # empty = AGENT_NAME (lowercased); otherwise e.g. antonia
# Behaviour AFTER a reply:
#   conversation = the conversation window stays open for WAKE_WORD_WINDOW_S,
#                  follow-up questions without the wake word are possible (default).
#   alexa        = one-shot: the window closes immediately after the reply,
#                  every new command needs the wake word again.
WAKE_MODE=conversation       # conversation | alexa
WAKE_WORD_WINDOW_S=8         # conversation window after a reply (s)
WAKE_WORD_FUZZY=1            # tolerate Whisper mishearings (Antonja/Anthonia/…)
WAKE_WORD_ANYWHERE=0         # 1 = wake word anywhere in the sentence instead of only at the start
WAKE_WORD_STRIP=1            # cut the wake word out of the text before the LLM
WAKE_WORD_RATIO=0.78         # fuzzy threshold (higher = stricter)

# === House Mode (optional, default off) ===
# Umbrella switch for the multi-user "house" features. The three sub-flags below
# each default to the value of HOUSE_MODE, so HOUSE_MODE=1 turns them all on;
# set a sub-flag explicitly to override it individually. NOTE: speaker
# IDENTIFICATION (HOUSE_SPEAKER_ID) needs an external `speaker_id` module that is
# not shipped in this repo — it stays disabled until that module is present. For
# single-owner voice gating use the Speaker-lock section below instead.
HOUSE_MODE=0
HOUSE_DATA_DIR=./house_data
#HOUSE_SPEAKER_ID=            # multi-speaker identification (needs the external module)
#HOUSE_WAKE_WORD=            # per-house wake-word handling
#HOUSE_AUTH=                 # house authentication

# === Speaker lock (voice gate, optional, default off) ===
# Only segments whose voice matches the ENROLLED owner profile are transcribed;
# any other voice (kids/guests/TV in the background) is dropped before the LLM.
# This is speaker VERIFICATION (1 enrolled voice), independent of the wake word
# and of STT — it works with any STT backend. Enroll your voice from the UI
# ("learn my voice"); the profile is written to SPEAKER_PROFILE_PATH.
#
# Needs sherpa-onnx + a speaker-embedding model (imported only when enabled):
#   pip install sherpa-onnx
#   model: a CAM++/WeSpeaker ONNX from
#   https://github.com/k2-fsa/sherpa-onnx/releases/tag/speaker-recongition-models
#   recommended: 3dspeaker_speech_campplus_sv_zh_en_16k-common_advanced.onnx
#   (~28 MB; benchmarked FAR better owner-vs-foreign separation on real field
#   audio than campplus_en_voxceleb_16k.onnx — block gap +0.58 vs +0.03).
#   The profile is model-specific: switching models requires re-enrolling.
SPEAKER_LOCK_ENABLED=0
SPEAKER_MODEL_PATH=          # absolute path to the .onnx embedding model
SPEAKER_PROFILE_PATH=        # default: ./speaker_profile.json (enrolled voice)
SPEAKER_THRESHOLD=0.5        # cosine similarity to accept (higher = stricter)
SPEAKER_MIN_DUR_S=0.6        # shorter segments can't be verified → dropped
SPEAKER_TRIM=1               # mixed segments: cut sustained foreign passages
                             # (3s block check + one extra STT call when mixed)
SPEAKER_DEBUG=0              # log per-block scores per segment (threshold tuning)
#SPEAKER_DUMP_DIR=           # dump gated segments + enroll takes as WAVs here
                             # (offline gate debugging; newest ~200 kept)
SPEAKER_PROVIDER=cpu         # onnxruntime provider: cpu | cuda
SPEAKER_NUM_THREADS=1

# === Hermes Memory Integration (optional) ===
# Stable session key for the voice chat's own Hermes memory session (sent as
# X-Hermes-Session-Id; plain OpenAI-compatible backends ignore it). Empty =
# no Hermes binding.
HERMES_SESSION_KEY_SEPARATE=
# Where the active Hermes session ID is persisted after a "New session" reset,
# so reconnects/reloads stay in the fresh session instead of snapping back to
# the pre-reset one. Default: <project>/.hermes_session_id
#HERMES_SESSION_STATE_PATH=

# === Warmups (optional, default off) ===
# Fire one throwaway STT/TTS call at startup so the first REAL user turn doesn't
# pay the cold-start cost. Most useful for self-hosted endpoints that lazy-load a
# model on first request (local Whisper, the OmniVoice wrapper). The cloud
# default rarely needs it.
STT_WARMUP=0
TTS_WARMUP=0

# === Pronunciation lexicon (optional) ===
# JSON file of {word: spoken-replacement} applied to the reply text right before
# TTS (whole-word, case-insensitive) — fixes names/brands/acronyms the voice
# mangles, e.g. {"GdW": "Ge de We", "Helm & Walter": "Helm und Walter"}. Keys
# starting with "_" are ignored (use them for comments). Reloaded automatically
# when the file's mtime changes. Default: <project>/pronunciations.json if present.
#VOICE_PRONUNCIATIONS=

# === Shared API keys (fallback, when STT/TTS/LLM use the same provider) ===
OPENAI_API_KEY=sk-...
FIREWORKS_API_KEY=fw_...
