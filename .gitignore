tools/enroll_house_speakers.py
tools/enroll_joy_profile.py

# Backups / Editor / OS
*_orig.py
*.bak
.DS_Store
*.swp
# Optionales House-Mode-Artefakt (nicht im Repo)
speakers.json

# .env-Backups (enthalten Secrets)
