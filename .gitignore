models/
*.onnx
speaker_profile.json
# Single-Mode-Profile pro Agent (biometrische Stimm-Embeddings)
speaker_profile_*.json
# Enroll-Rohdaten (private Sprachaufnahmen)
enroll_samples/
# Stimm-Referenzsamples für Voice-Cloning (private Aufnahmen)
voices/
